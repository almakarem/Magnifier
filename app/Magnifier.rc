// Magnifier.rc - version info + tray/window icon.
#include <winver.h>
#include "resource.h"

// IDI_APP must match the constant used by LoadIcon(hinst, MAKEINTRESOURCEW(IDI_APP))
// in the runtime. Keep in sync with src/util/Resources.h.
//
// The ICON statement is wrapped in HAVE_ICON because the .ico binary is
// optional: CMake defines HAVE_ICON only when app/Magnifier.ico exists on
// disk, so the build still succeeds before the user generates the icon
// (the runtime falls back to LoadIcon(nullptr, IDI_APPLICATION) when the
// resource is absent).
#ifdef HAVE_ICON
IDI_APP ICON "Magnifier.ico"
#endif

VS_VERSION_INFO VERSIONINFO
FILEVERSION    0,1,6,0
PRODUCTVERSION 0,1,6,0
FILEFLAGSMASK  0x3fL
#ifdef _DEBUG
FILEFLAGS      0x1L
#else
FILEFLAGS      0x0L
#endif
FILEOS         0x40004L
FILETYPE       0x1L
FILESUBTYPE    0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "AMSA"
            VALUE "FileDescription",  "Low-latency overlay magnifier for Windows"
            VALUE "FileVersion",      "0.1.6.0"
            VALUE "InternalName",     "Magnifier"
            VALUE "LegalCopyright",   "Copyright (c) 2026 AMSA - MIT License"
            VALUE "OriginalFilename", "Magnifier.exe"
            VALUE "ProductName",      "Magnifier"
            VALUE "ProductVersion",   "0.1.6.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END
